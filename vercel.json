{
  "version": 2,
  "functions": {
    "api/get-data.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_SECRET_KEY": "@supabase_secret_key"
  }
}